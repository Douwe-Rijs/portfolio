# Canonical site URL — used for SEO canonical tags, sitemap and Open Graph.
# Defaults to the free Vercel domain; switch to https://standofl.nl (or a
# subdomain) once the custom domain is attached in Vercel. No code change needed.
SITE_URL="https://portfolio.vercel.app"

# Vercel Web Analytics is cookieless and auto-enabled when deployed on Vercel.
# No key required. Set to "false" to disable the client component locally.
PUBLIC_ENABLE_ANALYTICS="true"
