---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/**
 * A slow, edge-to-edge film strip of project imagery — a human, portfolio-book
 * touch for the homepage. Pure CSS animation (0 JS): the track holds two
 * copies of the image set and translates by half its width for a seamless
 * loop. Under `prefers-reduced-motion` the global CSS kills the animation and
 * the strip becomes a static row. Each frame links to its case study.
 */
interface MarqueeImage {
  src: ImageMetadata;
  alt: string;
  href: string;
}
interface Props {
  images: MarqueeImage[];
  /** Seconds for one full loop. Slower = calmer. */
  duration?: number;
}

const { images, duration = 60 } = Astro.props;
---

<div class="marquee group/marquee overflow-hidden border-y border-line bg-surface">
  <div class="marquee-track flex w-max" style={`--marquee-duration:${duration}s`}>
    {
      [0, 1].map((copy) => (
        <ul class="flex" aria-hidden={copy === 1 ? 'true' : undefined}>
          {images.map((img) => (
            <li class="flex-none">
              <a
                href={img.href}
                tabindex={copy === 1 ? -1 : undefined}
                class="block p-3 transition-opacity hover:opacity-80"
              >
                <Image
                  src={img.src}
                  alt={copy === 0 ? img.alt : ''}
                  height={224}
                  widths={[420]}
                  sizes="420px"
                  loading="lazy"
                  class="h-40 w-auto max-w-none rounded-lg border border-line object-cover sm:h-56"
                />
              </a>
            </li>
          ))}
        </ul>
      ))
    }
  </div>
</div>

<style>
  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  .marquee-track {
    animation: marquee-scroll var(--marquee-duration, 60s) linear infinite;
  }
  /* Let people read/click: pause while hovering or focused within. */
  .marquee:hover .marquee-track,
  .marquee:focus-within .marquee-track {
    animation-play-state: paused;
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
    .marquee {
      overflow-x: auto;
    }
  }
</style>
