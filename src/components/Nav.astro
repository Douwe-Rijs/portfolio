---
import { NAV, SITE } from '@/consts';
import ThemeToggle from '@/components/ThemeToggle.tsx';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(`${href}/`);
---

<header
  class="sticky top-0 z-50 border-b border-line/70 bg-base/80 backdrop-blur-sm"
  transition:persist
>
  <nav
    aria-label="Primary"
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4"
  >
    <a
      href="/"
      class="font-display text-lg tracking-tight text-ink"
      aria-label={`${SITE.name} — home`}
    >
      {SITE.name}
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      <ul class="flex items-center gap-1 text-sm sm:gap-2">
        {
          NAV.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class="rounded-full px-2.5 py-1.5 text-muted transition-colors hover:text-ink aria-[current=page]:text-ink"
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <ThemeToggle client:load />
    </div>
  </nav>
</header>
