---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/**
 * Edge-to-edge image that breaks out of the reading column to the full
 * viewport width — the signature move of the `showcase` vibe. Optional caption
 * sits back inside the column for legibility.
 */
interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  /** Tailwind height/aspect classes, e.g. "aspect-[21/9]" or "h-[80vh]". */
  ratio?: string;
  widths?: number[];
  priority?: boolean;
  /** Reveal on scroll when used inside the `motion` preset. */
  reveal?: boolean;
}

const {
  src,
  alt,
  caption,
  ratio = 'aspect-[16/9]',
  widths = [768, 1280, 1920, 2400],
  priority = false,
  reveal = false,
} = Astro.props;
---

<figure class="not-prose full-bleed my-[var(--rhythm)]" data-reveal={reveal ? 'out' : undefined}>
  <Image
    src={src}
    alt={alt}
    widths={widths}
    sizes="100vw"
    loading={priority ? 'eager' : 'lazy'}
    class={`w-full ${ratio} object-cover`}
  />
  {
    caption && (
      <figcaption class="mx-auto mt-3 max-w-6xl px-6 font-mono text-xs text-muted">
        {caption}
      </figcaption>
    )
  }
</figure>
