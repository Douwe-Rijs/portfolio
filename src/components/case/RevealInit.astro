---
/**
 * Scroll-reveal initialiser for the `motion` vibe. Finds elements marked
 * `data-reveal="out"` and flips them to `"in"` as they enter the viewport. Pure
 * IntersectionObserver — no framework — so the page stays JS-light. Reduced
 * motion is already handled in CSS (revealed elements render instantly).
 */
---

<script is:inline>
  (() => {
    const init = () => {
      const targets = document.querySelectorAll('[data-reveal="out"]');
      if (!targets.length) return;
      if (
        !('IntersectionObserver' in window) ||
        window.matchMedia('(prefers-reduced-motion: reduce)').matches
      ) {
        targets.forEach((el) => el.setAttribute('data-reveal', 'in'));
        return;
      }
      const io = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.setAttribute('data-reveal', 'in');
              obs.unobserve(entry.target);
            }
          });
        },
        { rootMargin: '0px 0px -10% 0px', threshold: 0.1 },
      );
      targets.forEach((el) => io.observe(el));
    };
    init();
    document.addEventListener('astro:page-load', init);
  })();
</script>
