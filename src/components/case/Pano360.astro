---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Pano360Island from './Pano360.tsx';

/**
 * Astro wrapper for the 360° panorama island: optimises the equirectangular
 * image at build time and mounts the drag-to-pan viewer full-bleed, with an
 * optional caption back inside the reading column.
 */
interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  height?: string;
  driftSpeed?: number;
}

const { src, alt, caption, height = '60vh', driftSpeed = 12 } = Astro.props;

// A single wide rendition: panoramas are one big strip, not a srcset case.
const optimized = await getImage({ src, width: 2400, format: 'webp' });
---

<figure class="not-prose full-bleed my-[var(--rhythm)]">
  <Pano360Island
    client:visible
    src={optimized.src}
    alt={alt}
    height={height}
    driftSpeed={driftSpeed}
  />
  {
    caption && (
      <figcaption class="mx-auto mt-3 max-w-6xl px-6 font-mono text-xs text-muted">
        {caption}
      </figcaption>
    )
  }
</figure>
