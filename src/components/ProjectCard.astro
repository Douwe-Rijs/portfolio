---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  priority?: boolean;
}

const { project, priority = false } = Astro.props;
const { data } = project;

// Surface each project's own accent on its card so the index hints the vibe.
const cardStyle = data.theme?.accent ? `--accent:${data.theme.accent}` : undefined;
---

<a href={`/work/${project.id}`} class="group block" style={cardStyle}>
  <article>
    <div class="overflow-hidden rounded-xl border border-line bg-surface">
      <Image
        src={data.heroImage}
        alt={data.heroAlt}
        widths={[480, 800, 1200]}
        sizes="(min-width: 640px) 50vw, 100vw"
        loading={priority ? 'eager' : 'lazy'}
        class="aspect-[16/10] w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
      />
    </div>
    <div class="mt-5">
      <div class="flex items-center gap-3 font-mono text-xs tracking-wider text-muted uppercase">
        <span>{data.role}</span>
        <span aria-hidden="true">·</span>
        <span>{data.timeframe}</span>
      </div>
      <h3 class="mt-2 font-display text-2xl text-ink">{data.title}</h3>
      <p class="mt-2 max-w-prose text-muted">{data.summary}</p>
      {
        data.tech.length > 0 && (
          <ul class="mt-4 flex flex-wrap gap-2">
            {data.tech.slice(0, 5).map((t) => (
              <li class="rounded-full border border-line px-2.5 py-1 font-mono text-xs text-muted">
                {t}
              </li>
            ))}
          </ul>
        )
      }
      <span class="mt-4 inline-flex items-center gap-1 text-sm text-accent">
        View case study
        <span class="transition-transform group-hover:translate-x-0.5" aria-hidden="true">→</span>
      </span>
    </div>
  </article>
</a>
