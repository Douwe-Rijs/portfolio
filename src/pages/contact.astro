---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SOCIALS } from '@/consts';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Douwe Rijs about robotics & ML thesis placements, roles and collaborations."
>
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-24 sm:pt-28">
    <h1 class="display-lg text-ink">Contact</h1>
    <p class="mt-8 max-w-2xl text-lg leading-relaxed text-muted">
      I’m open to MSc thesis placements, robotics &amp; ML roles, and interesting collaborations.
      The best way to reach me is email or LinkedIn.
    </p>

    <div class="mt-10 space-y-4">
      <p class="flex items-baseline gap-4">
        <span class="w-24 shrink-0 font-mono text-xs tracking-wider text-muted uppercase"
          >Email</span
        >
        <button
          id="contact-email"
          type="button"
          class="cursor-pointer text-accent underline-offset-4 hover:underline"
        >
          reveal email
        </button>
        <noscript><span class="text-ink">Douwe [at] standofl [dot] nl</span></noscript>
      </p>
      {
        SOCIALS.map((s) => (
          <p class="flex items-baseline gap-4">
            <span class="w-24 shrink-0 font-mono text-xs tracking-wider text-muted uppercase">
              {s.label}
            </span>
            <a
              class="text-ink underline-offset-4 hover:underline"
              href={s.href}
              target="_blank"
              rel="me noopener"
            >
              {s.href.replace(/^https?:\/\/(www\.)?/, '')}
            </a>
          </p>
        ))
      }
    </div>
  </section>

  {/* Assemble the address client-side to deter naive scrapers; no email in static HTML. */}
  <script is:inline>
    (() => {
      const user = 'Douwe';
      const domain = 'standofl.nl';
      const el = document.getElementById('contact-email');
      if (el) {
        const addr = user + '@' + domain;
        el.textContent = addr;
        el.addEventListener('click', () => {
          window.location.href = 'mailto:' + addr;
        });
      }
    })();
  </script>
</BaseLayout>
