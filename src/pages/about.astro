---
import BaseLayout from '@/layouts/BaseLayout.astro';

const skills: { group: string; items: string[] }[] = [
  { group: 'Programming', items: ['Python', 'C++', 'Go', 'TypeScript / JavaScript', 'MATLAB'] },
  {
    group: 'ML & Perception',
    items: ['Transformers', 'CNNs', 'VLMs', 'Sensor fusion', 'Kalman filtering'],
  },
  { group: 'Robotics', items: ['Control (PID)', 'Motion planning', 'Dynamics'] },
  { group: 'Tools', items: ['Docker', 'Linux', 'Git', 'CI/CD', 'Azure DevOps'] },
];
---

<BaseLayout
  title="About"
  description="Douwe Rijs — robotics & ML engineer working across the autonomy stack: perception, planning and control."
>
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-12 sm:pt-28">
    <h1 class="display-lg text-ink">About</h1>
    <div class="mt-8 space-y-5 text-lg leading-relaxed text-muted">
      <p>
        I’m Douwe Rijs, a robotics and machine-learning engineer based in Delft. I’m completing an
        MSc in Robotics at TU Delft — building on a BSc in Mechanical Engineering and a minor in
        Computer Science — while working as an Assistant R&amp;D Engineer at Allseas.
      </p>
      <p>
        My focus is the full autonomy stack: <span class="text-ink"
          >perception, planning and control</span
        >. I’m drawn to problems where the data is noisy, the environment is unforgiving, and the
        system still has to work — from optical-flow flight control on a micro air vehicle to
        multi-sensor 3D detection on real driving data.
      </p>
      <p>
        I like turning research-grade ideas into software that runs reliably outside the lab, and I
        care about the unglamorous parts — observability, CI/CD and reproducibility — that make that
        possible.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-3xl border-t border-line px-6 py-12">
    <h2 class="font-display text-2xl text-ink">Skills</h2>
    <dl class="mt-8 grid gap-x-10 gap-y-8 sm:grid-cols-2">
      {
        skills.map((s) => (
          <div>
            <dt class="font-mono text-xs tracking-wider text-muted uppercase">{s.group}</dt>
            <dd class="mt-3 flex flex-wrap gap-2">
              {s.items.map((i) => (
                <span class="rounded-full border border-line px-3 py-1 text-sm text-ink">{i}</span>
              ))}
            </dd>
          </div>
        ))
      }
    </dl>
  </section>
</BaseLayout>
