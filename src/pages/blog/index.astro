---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';

// Only non-draft posts are ever listed. Until the first post ships this page is
// intentionally empty and unlinked from the nav.
const posts = (await getCollection('posts', (p) => !p.data.draft)).sort(
  (a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf(),
);

const dateFmt = new Intl.DateTimeFormat('en', { dateStyle: 'long' });
---

<BaseLayout
  title="Writing"
  description="Notes on robotics, perception and machine-learning engineering by Douwe Rijs."
>
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-10 sm:pt-28">
    <h1 class="display-lg text-ink">Writing</h1>
    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-muted">
      Occasional notes on the engineering behind the projects — perception, control, ML systems and
      the messy realities in between.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-6 pb-24">
    {
      posts.length > 0 ? (
        <ul class="divide-y divide-line border-t border-line">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}`} class="group flex flex-col gap-1 py-6">
                <span class="font-mono text-xs tracking-wider text-muted uppercase">
                  {dateFmt.format(post.data.publishedDate)}
                </span>
                <h2 class="font-display text-2xl text-ink transition-colors group-hover:text-accent">
                  {post.data.title}
                </h2>
                <p class="text-muted">{post.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="max-w-prose text-lg text-muted">
          The first post is on its way — check back soon.
        </p>
      )
    }
  </section>
</BaseLayout>
