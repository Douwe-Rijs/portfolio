---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import CaseStudy from '@/components/case/CaseStudy.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', (p) => p.data.status === 'published');
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { data } = project;

const seoTitle = data.seo?.title ?? data.title;
const seoDesc = data.seo?.description ?? data.summary;
---

<BaseLayout title={seoTitle} description={seoDesc} type="article">
  <CaseStudy project={project} />
</BaseLayout>
